---
import Base from '../layouts/Base.astro';

const services = [
  {
    id: 'margin-recovery',
    number: '01',
    title: 'Margin Recovery',
    kicker: 'Lean Six Sigma DMAIC Sprints',
    body: 'A 90-day engagement going after the 2 to 4 points of net margin that hide in labor time variance, late change orders, material waste, and stale estimating assumptions.',
    bullets: ['Value-stream mapping', 'Standard work + SOPs', 'KPI dashboards', 'Optional gainshare pricing'],
  },
  {
    id: 'fractional-pmo',
    number: '02',
    title: 'Fractional PMO',
    kicker: 'Program Governance on Retainer',
    body: 'For owners running too many initiatives at once. Portfolio visibility, a steering cadence, risk and dependency tracking, and stage-gate reviews. Enterprise rigor at small-business scale.',
    bullets: ['Portfolio dashboard', 'Biweekly steering', 'Risk + dependency mapping', 'Vendor / sub oversight'],
  },
  {
    id: 'software-adoption',
    number: '03',
    title: 'Software Adoption',
    kicker: 'Make What You Bought Actually Work',
    body: "Procore, Buildertrend, HubSpot, ERP, BI. Most teams use about 30% of what they pay for. We design the workflow, migrate the data, train the roles, and build the reporting layer that makes people want to use it.",
    bullets: ['Workflow design', 'Data migration', 'Role-based training', 'Reporting & dashboards'],
  },
  {
    id: 'grant-programs',
    number: '04',
    title: 'Grant & Rebuild Programs',
    kicker: 'CDBG-DR · FEMA · Federal Compliance',
    body: 'Help navigating Helene and Milton recovery funds and other federal grant flows. Davis-Bacon, environmental review, draw schedules, and the audit-ready documentation that gets you paid.',
    bullets: ['Eligibility + readiness', 'Contractor compliance PMO', 'Draw + documentation', 'Closeout support'],
  },
];

const industries = [
  { label: 'Construction & Trades', icon: 'construction' },
  { label: 'Healthcare', icon: 'health' },
  { label: 'Logistics & 3PL', icon: 'logistics' },
  { label: 'Professional Services', icon: 'briefcase' },
  { label: 'Government & Nonprofit', icon: 'gov' },
];

const stats = [
  { value: '10+', label: 'Years leading enterprise programs' },
  { value: '75+', label: 'KPIs governed across federal operations' },
  { value: '$2–4pt', label: 'Typical margin recovery target' },
  { value: '90-day', label: 'Sprint-based engagements' },
];

const process = [
  {
    n: '01',
    name: 'Listen',
    body: 'A 30-minute call. No deck. We listen for the actual problem, not the symptom you came in with. If we\'re not the right fit, we say so on the call.',
  },
  {
    n: '02',
    name: 'Measure',
    body: 'A short discovery to get baseline numbers on the workflows that matter. Without a measured starting point, every claim of improvement is just an opinion.',
  },
  {
    n: '03',
    name: 'Improve',
    body: 'A 90-day sprint with weekly checkpoints. Standard work, dashboards, and a daily cadence. We work alongside your people, not over them.',
  },
  {
    n: '04',
    name: 'Hand off',
    body: 'You finish with a team that can run the new operating rhythm without us. Documented SOPs, trained leads, and a clean exit. The goal is no permanent retainer.',
  },
];

const testimonials = [
  {
    quote: 'Cranes pulled three points of margin out of our operation in a single quarter. We thought we were running tight. We were not.',
    name: 'Owner, residential GC',
    detail: 'Tampa, FL · 18-person crew',
  },
  {
    quote: 'We had been paying for Procore for two years and our team used about a third of it. Tyler\'s team rebuilt our workflow and got real adoption inside 60 days.',
    name: 'Operations director',
    detail: 'Light-commercial contractor',
  },
  {
    quote: 'Federal-grade discipline applied to a small-business problem. Our weekly cadence is unrecognizable from where we were six months ago.',
    name: 'Practice administrator',
    detail: 'Multi-site healthcare practice',
  },
];

const faqs = [
  {
    q: 'How quickly can we start?',
    a: 'Most engagements kick off within two weeks of a signed proposal. If you\'re inside a hurricane recovery deadline or a CDBG-DR draw cycle, we move faster.',
  },
  {
    q: 'Do you work with companies outside Tampa Bay?',
    a: 'Most of our clients are in Tampa, St. Petersburg, Clearwater, Lakeland, and the I-4 corridor. We do remote-first engagements for clients elsewhere in Florida and the Southeast when it fits the work.',
  },
  {
    q: 'How much do engagements typically cost?',
    a: 'A 90-day Margin Recovery Sprint runs $25K to $50K with optional gainshare. Fractional PMO retainers run $6K to $15K per month. Software implementations run $15K to $35K. See the Services page for specifics.',
  },
  {
    q: 'What happens on the free 30-minute audit?',
    a: 'You bring a real operational problem. We bring a Lean Six Sigma playbook and ten years of program-management discipline. We talk for 30 minutes, then either propose a scope or send you off with two or three things you can fix yourself.',
  },
  {
    q: 'Are you Lean Six Sigma certified?',
    a: 'Yes. Black Belt certified, Prosci change-management certified, PMP in progress. We use those frameworks because they work, not as marketing.',
  },
  {
    q: 'Will you work with our existing tools, or do we have to switch?',
    a: 'We work with your existing stack. Power BI, Procore, Buildertrend, HubSpot, QuickBooks, whatever you already run. We are not in the business of selling you new software.',
  },
];
---
<Base>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-bone-100">
    <div aria-hidden="true" class="absolute inset-0 bg-grid-navy bg-[size:32px_32px] opacity-60 [mask-image:radial-gradient(ellipse_at_center,black_40%,transparent_80%)]"></div>

    <div class="container-x relative py-20 md:py-28 lg:py-32">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <span class="eyebrow">Tampa Bay · Operations Partners</span>

          <h1 class="mt-6 text-balance text-4xl md:text-5xl lg:text-[56px] font-extrabold leading-[1.05] tracking-tightest text-navy-900">
            Operations that scale.
            <span class="block text-amber-700">Margin that holds.</span>
          </h1>

          <p class="mt-6 max-w-2xl text-lg md:text-xl text-pretty text-ink-soft leading-relaxed">
            We're Cranes Consulting, a small team of operations partners helping Tampa Bay small businesses tighten up the operations side so growth doesn't eat your margin. The toolkit is Lean Six Sigma plus a decade of running federal programs at scale. Engagements are sprint-based with fixed fees, not open-ended retainers.
          </p>

          <div class="mt-9 flex flex-wrap items-center gap-4">
            <a href="/contact" class="btn-accent">
              Get a free 30-min audit
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href="/services" class="btn-ghost">
              See how we work
            </a>
          </div>

          <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2">
            <span class="label-chip">
              <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
              Lean Six Sigma Black Belt
            </span>
            <span class="label-chip">
              <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
              Prosci Change Management
            </span>
            <span class="label-chip">
              <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
              PMP (in progress)
            </span>
          </div>
        </div>

        <!-- Visual panel -->
        <div class="lg:col-span-5 relative">
          <div class="relative rounded-2xl bg-white border border-navy-100 shadow-card-lg overflow-hidden">
            <div class="bg-navy-900 px-6 py-4 flex items-center justify-between">
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-300">Margin Recovery Snapshot</span>
              <span class="text-[10px] uppercase tracking-widest text-navy-300">Q2 · Illustrative</span>
            </div>

            <div class="p-6 space-y-5">
              <div>
                <div class="flex items-baseline justify-between">
                  <p class="text-sm font-medium text-ink-soft">Labor time variance</p>
                  <p class="text-sm font-semibold text-amber-600">−42%</p>
                </div>
                <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-navy-50">
                  <div class="h-full w-[58%] rounded-full bg-gradient-to-r from-amber-400 to-amber-500"></div>
                </div>
              </div>

              <div>
                <div class="flex items-baseline justify-between">
                  <p class="text-sm font-medium text-ink-soft">Change-order cycle time</p>
                  <p class="text-sm font-semibold text-amber-600">−61%</p>
                </div>
                <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-navy-50">
                  <div class="h-full w-[39%] rounded-full bg-gradient-to-r from-amber-400 to-amber-500"></div>
                </div>
              </div>

              <div>
                <div class="flex items-baseline justify-between">
                  <p class="text-sm font-medium text-ink-soft">Net margin lift</p>
                  <p class="text-sm font-semibold text-amber-600">+3.1 pts</p>
                </div>
                <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-navy-50">
                  <div class="h-full w-[72%] rounded-full bg-gradient-to-r from-amber-400 to-amber-500"></div>
                </div>
              </div>

              <div class="pt-4 border-t border-navy-100 grid grid-cols-3 gap-3">
                <div>
                  <p class="text-[10px] uppercase tracking-widest text-ink-mute">Phase</p>
                  <p class="text-sm font-semibold text-navy-800 mt-1">Improve</p>
                </div>
                <div>
                  <p class="text-[10px] uppercase tracking-widest text-ink-mute">Weeks in</p>
                  <p class="text-sm font-semibold text-navy-800 mt-1">7 / 13</p>
                </div>
                <div>
                  <p class="text-[10px] uppercase tracking-widest text-ink-mute">Savings</p>
                  <p class="text-sm font-semibold text-navy-800 mt-1">$186K</p>
                </div>
              </div>
            </div>
          </div>

          <div class="absolute -bottom-6 -left-6 hidden md:block rounded-xl bg-navy-800 text-white px-5 py-4 shadow-card-lg border border-navy-700">
            <p class="text-[10px] uppercase tracking-widest text-amber-300 font-semibold">Anchor offer</p>
            <p class="mt-1 text-sm font-semibold">90-Day Margin Recovery Sprint</p>
            <p class="text-xs text-navy-200 mt-0.5">Fixed fee + optional gainshare.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <section class="bg-navy-900 text-bone-100">
    <div class="container-x py-12 grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map((s) => (
        <div>
          <p class="text-3xl md:text-4xl font-extrabold tracking-tightest text-amber-300">{s.value}</p>
          <p class="mt-2 text-xs uppercase tracking-[0.18em] text-navy-200">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- VALUE PROP -->
  <section class="container-x py-20 md:py-28">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <span class="eyebrow">Why work with us</span>
        <h2 class="mt-5 text-3xl md:text-4xl font-extrabold text-balance leading-[1.1]">
          Big-firm operating discipline at small-firm economics.
        </h2>
      </div>
      <div class="lg:col-span-7 grid sm:grid-cols-2 gap-6">
        <div class="card p-6">
          <div class="h-10 w-10 rounded-lg bg-amber-100 text-amber-600 grid place-items-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">Results show up in the P&amp;L</h3>
          <p class="mt-2 text-sm text-ink-soft leading-relaxed">
            Every engagement starts with a measured baseline and ends with an improvement you can point to in your numbers. No vanity slides.
          </p>
        </div>
        <div class="card p-6">
          <div class="h-10 w-10 rounded-lg bg-amber-100 text-amber-600 grid place-items-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M8 12h8M8 8h8M8 16h5"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">Real program rigor</h3>
          <p class="mt-2 text-sm text-ink-soft leading-relaxed">
            A decade running enterprise programs at federal scale taught us how to use risk registers, stage gates, and audit-ready documentation without making the team hate us. That same discipline scales down to small businesses.
          </p>
        </div>
        <div class="card p-6">
          <div class="h-10 w-10 rounded-lg bg-amber-100 text-amber-600 grid place-items-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 2v20M2 12h20"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">Multiple industries</h3>
          <p class="mt-2 text-sm text-ink-soft leading-relaxed">
            Construction, healthcare, logistics, professional services. The Lean Six Sigma toolkit works across all of them. The judgement about which lever to pull is what changes.
          </p>
        </div>
        <div class="card p-6">
          <div class="h-10 w-10 rounded-lg bg-amber-100 text-amber-600 grid place-items-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">Defined start and end</h3>
          <p class="mt-2 text-sm text-ink-soft leading-relaxed">
            Most engagements are 90-day sprints with fixed fees and clear deliverables. Scope changes, we re-scope. Nobody gets stuck on an open-ended retainer.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="bg-bone-200/60 border-y border-navy-100">
    <div class="container-x py-20 md:py-28">
      <div class="max-w-2xl">
        <span class="eyebrow">Services</span>
        <h2 class="mt-5 text-3xl md:text-4xl font-extrabold text-balance leading-[1.1]">
          Four lanes. One operating system for growing businesses.
        </h2>
        <p class="mt-4 text-ink-soft text-lg">
          Start where the pain is sharpest. Margin, overload, a shelfware system, a grant deadline. Then layer from there.
        </p>
      </div>

      <div class="mt-12 grid md:grid-cols-2 gap-6">
        {services.map((s) => (
          <a href={`/services#${s.id}`} class="card p-7 group block">
            <div class="flex items-start justify-between gap-6">
              <div>
                <p class="font-mono text-xs text-amber-600 font-bold tracking-widest">{s.number}</p>
                <h3 class="mt-2 text-xl md:text-2xl font-bold">{s.title}</h3>
                <p class="mt-1 text-xs uppercase tracking-[0.18em] text-ink-mute font-semibold">{s.kicker}</p>
              </div>
              <span class="h-9 w-9 shrink-0 rounded-full border border-navy-200 text-navy-700 grid place-items-center group-hover:bg-navy-800 group-hover:border-navy-800 group-hover:text-white transition-colors">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </div>
            <p class="mt-5 text-sm text-ink-soft leading-relaxed">{s.body}</p>
            <ul class="mt-4 grid grid-cols-2 gap-2">
              {s.bullets.map((b) => (
                <li class="flex items-start gap-2 text-xs text-ink-soft">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-amber-600 mt-0.5 shrink-0"><path d="m5 12 5 5L20 7"/></svg>
                  {b}
                </li>
              ))}
            </ul>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="container-x py-20 md:py-28">
    <div class="max-w-2xl">
      <span class="eyebrow">Industries we work with</span>
      <h2 class="mt-5 text-3xl md:text-4xl font-extrabold text-balance leading-[1.1]">
        Wherever process and margin collide.
      </h2>
    </div>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
      {industries.map((i) => (
        <div class="card p-6 text-center">
          <div class="mx-auto h-10 w-10 rounded-lg bg-navy-50 text-navy-700 grid place-items-center">
            {i.icon === 'construction' && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 20h16M6 20V9l6-4 6 4v11M10 20v-6h4v6"/></svg>}
            {i.icon === 'health' && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 21s-7-4.5-7-11a5 5 0 0 1 10-1 5 5 0 0 1 10 1c0 6.5-7 11-7 11"/></svg>}
            {i.icon === 'logistics' && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 7h13v10H3zM16 10h4l1 3v4h-5"/><circle cx="7" cy="19" r="2"/><circle cx="18" cy="19" r="2"/></svg>}
            {i.icon === 'briefcase' && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>}
            {i.icon === 'gov' && <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 21h18M5 21V10l7-5 7 5v11M9 21v-6h6v6"/></svg>}
          </div>
          <p class="mt-3 text-sm font-semibold text-navy-800">{i.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- PROCESS -->
  <section class="bg-bone-200/60 border-y border-navy-100">
    <div class="container-x py-20 md:py-28">
      <div class="max-w-2xl">
        <span class="eyebrow">How we work</span>
        <h2 class="mt-5 text-3xl md:text-4xl font-extrabold text-balance leading-[1.1]">
          A four-step process. No mystery, no theatrics.
        </h2>
        <p class="mt-4 text-ink-soft text-lg">
          Most consultants make their methodology sound complicated. Ours is the opposite. Listen first, measure honestly, improve in a 90-day sprint, and hand off cleanly.
        </p>
      </div>

      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {process.map((step, i) => (
          <div class="card p-7 relative">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-amber-700 font-bold tracking-widest">{step.n}</span>
              {i < 3 && (
                <span aria-hidden="true" class="hidden lg:block absolute right-3 top-1/2 -translate-y-1/2 text-navy-200">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </span>
              )}
            </div>
            <h3 class="mt-3 text-xl font-bold text-navy-800">{step.name}</h3>
            <p class="mt-3 text-sm text-ink-soft leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="container-x py-20 md:py-28">
    <div class="max-w-2xl">
      <span class="eyebrow">What clients say</span>
      <h2 class="mt-5 text-3xl md:text-4xl font-extrabold text-balance leading-[1.1]">
        Outcomes you can put in a P&amp;L.
      </h2>
      <p class="mt-4 text-ink-soft text-lg">
        We measure success in points of margin recovered, hours saved, and software actually being used. The work shows up in your numbers.
      </p>
    </div>

    <div class="mt-12 grid md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <figure class="card p-7 flex flex-col">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-amber-500" aria-hidden="true"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
          <blockquote class="mt-5 text-ink-soft leading-relaxed flex-1">
            "{t.quote}"
          </blockquote>
          <figcaption class="mt-6 pt-5 border-t border-navy-100">
            <p class="text-sm font-semibold text-navy-800">{t.name}</p>
            <p class="text-xs text-ink-mute mt-0.5">{t.detail}</p>
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="mt-10 text-xs text-ink-mute italic max-w-prose-tight">
      Quotes condensed and identifying detail trimmed at clients' request. Real engagements, real numbers.
    </p>
  </section>

  <!-- FAQ -->
  <section class="bg-bone-200/60 border-y border-navy-100">
    <div class="container-x py-20 md:py-28 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4">
        <span class="eyebrow">Frequently asked</span>
        <h2 class="mt-5 text-3xl md:text-4xl font-extrabold text-balance leading-[1.1]">
          The questions we get most often.
        </h2>
        <p class="mt-4 text-ink-soft">
          Don't see yours? Email us at <a href="mailto:tyler@cranesconsultingfl.com" class="text-amber-700 underline decoration-amber-400/60 underline-offset-4 hover:decoration-amber-500">tyler@cranesconsultingfl.com</a>.
        </p>
      </div>

      <div class="lg:col-span-8 divide-y divide-navy-100 border-y border-navy-100">
        {faqs.map((f) => (
          <details class="group py-5">
            <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
              <h3 class="text-lg font-semibold text-navy-800 group-hover:text-amber-700 transition-colors">{f.q}</h3>
              <span class="shrink-0 mt-1 h-6 w-6 rounded-full border border-navy-200 text-navy-700 grid place-items-center group-open:bg-navy-800 group-open:border-navy-800 group-open:text-white transition-colors">
                <svg class="group-open:rotate-45 transition-transform" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <p class="mt-3 text-sm text-ink-soft leading-relaxed pr-12">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="container-x py-24">
    <div class="relative overflow-hidden rounded-2xl bg-navy-900 text-white px-8 py-14 md:px-14 md:py-20">
